<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Eva - Admin</title>
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif; background: #FCFCFC; color: #333; padding: 20px; max-width: 800px; margin: 0 auto; }
        h1 { font-family: Georgia, serif; font-size: 24px; margin-bottom: 4px; }
        .subtitle { color: #999; font-size: 13px; margin-bottom: 24px; }
        .card { background: #fff; border: 1px solid #eaeaea; border-radius: 16px; padding: 20px; margin-bottom: 16px; }
        label { font-size: 12px; font-weight: 700; color: #555; display: block; margin-bottom: 6px; margin-top: 12px; text-transform: uppercase; letter-spacing: 0.5px; }
        label:first-child { margin-top: 0; }
        textarea { width: 100%; padding: 12px; border: 1px solid #e0e0e0; border-radius: 10px; font-size: 14px; font-family: 'SF Mono', 'Menlo', 'Monaco', 'Courier New', monospace; resize: vertical; line-height: 1.5; }
        textarea.code-area { background: #1a1a2e; color: #e0e0e0; border-color: #2a2a4e; font-size: 13px; }
        textarea.code-area::placeholder { color: #666; }
        .row { display: flex; gap: 10px; flex-wrap: wrap; align-items: center; }
        .btn { padding: 12px 20px; border-radius: 12px; border: none; font-size: 14px; font-weight: 600; cursor: pointer; transition: all 0.2s; }
        .btn:active { transform: scale(0.95); }
        .btn-primary { background: #2563EB; color: #fff; }
        .btn-danger { background: #EF4444; color: #fff; font-size: 12px; padding: 8px 14px; }
        .btn-outline { background: #fff; border: 1px solid #e0e0e0; }
        .btn-sm { padding: 8px 14px; font-size: 12px; border-radius: 8px; }
        .list-item { background: #f9f9f9; border-radius: 12px; padding: 16px; margin-bottom: 10px; border-left: 3px solid #2563EB; }
        .list-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 8px; flex-wrap: wrap; gap: 8px; }
        .model-badge { display: inline-block; padding: 3px 10px; border-radius: 20px; font-size: 11px; font-weight: 700; }
        .badge-eva { background: #FDE8E8; color: #D48A72; }
        .badge-selene { background: #E8E0F0; color: #7C5CBF; }
        .badge-nyx { background: #1a1a2e; color: #e0e0e0; }
        .badge-aria { background: #E0F0F8; color: #3B82F6; }
        .preview { background: #f5f5f5; border-radius: 8px; padding: 10px 14px; font-size: 13px; color: #555; max-height: 80px; overflow-y: auto; white-space: pre-wrap; word-break: break-word; margin-top: 6px; font-style: italic; }
        .empty { text-align: center; color: #bbb; padding: 40px 20px; font-size: 14px; }
        .counter { font-size: 11px; color: #999; text-align: right; margin-top: 4px; }
        hr { border: none; border-top: 1px solid #eee; margin: 16px 0; }
        select { padding: 10px 12px; border: 1px solid #e0e0e0; border-radius: 10px; font-size: 14px; font-family: inherit; background: #fff; }
        .flex-between { display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 10px; }
        @media (max-width: 500px) { body { padding: 12px; } .card { padding: 14px; } }
    </style>
</head>
<body>

<h1>⚙️ Admin Eva</h1>
<p class="subtitle">Preguntas y respuestas personalizadas. Sin límites.</p>

<!-- AGREGAR NUEVO -->
<div class="card">
    <div class="flex-between">
        <h2 style="font-size:16px;">➕ Agregar nueva entrada</h2>
        <select id="modelSelect">
            <option value="eva">Eva</option>
            <option value="selene">Selene</option>
            <option value="nyx">Nyx</option>
            <option value="aria">Aria</option>
        </select>
    </div>
    
    <label>🔑 Keywords (palabras que activan esta respuesta, separadas por coma)</label>
    <textarea id="newKeywords" rows="2" placeholder="hola, hey, saludos, buenas"></textarea>
    <div class="counter" id="keywordsCounter">0 keywords</div>
    
    <label>💬 Respuesta</label>
<div style="position:relative;">
    <textarea id="newResponse" class="code-area" rows="10" placeholder="Pega aquí la respuesta. Si es código, se verá con color al guardar." oninput="updatePreview()"></textarea>
    <button type="button" onclick="formatCode()" style="position:absolute;top:8px;right:8px;background:#e94560;color:#fff;border:none;padding:4px 10px;border-radius:6px;font-size:11px;cursor:pointer;font-weight:bold;">🎨 Formatear</button>
</div>
<div id="codePreview" style="display:none;margin-top:8px;background:#1a1a2e;border-radius:10px;padding:15px;overflow-x:auto;font-family:'SF Mono','Menlo','Monaco',monospace;font-size:13px;line-height:1.6;color:#e0e0e0;max-height:300px;overflow-y:auto;"></div>
    <div class="counter" id="responseCounter">0 caracteres</div>
    
    <button class="btn btn-primary" onclick="addEntry()" style="margin-top:12px;width:100%;">✅ Agregar</button>
</div>

<!-- LISTA DE ENTRADAS -->
<div class="card">
    <div class="flex-between">
        <h2 style="font-size:16px;">📋 Entradas guardadas</h2>
        <button class="btn btn-outline btn-sm" onclick="exportData()">📤 Exportar</button>
<button class="btn btn-outline btn-sm" onclick="searchEntries()">🔍 Buscar</button>
<button class="btn btn-danger btn-sm" onclick="deleteByKeyword()">🗑 Borrar por palabra</button>
<button class="btn btn-outline btn-sm" onclick="addBatchFromJSON()">📥 Agregar lote</button>
        <button class="btn btn-outline btn-sm" onclick="importData()">📥 Importar archivo</button>
        <button class="btn btn-danger btn-sm" onclick="resetAll()">🗑 Borrar todo</button>
    </div>
    <input type="file" id="importFile" accept=".json" style="display:none" onchange="handleImport(event)">
    <div id="entriesList"></div>
</div>

<script>
// ============ DATOS ============
function getEntries() {
    return JSON.parse(localStorage.getItem('eva_entries') || '[]');
}

function saveEntries(data) {
    localStorage.setItem('eva_entries', JSON.stringify(data));
    renderEntries();
}

// ============ CONTADORES ============
document.getElementById('newKeywords').addEventListener('input', function() {
    var count = this.value.split(',').filter(function(k) { return k.trim() !== ''; }).length;
    document.getElementById('keywordsCounter').textContent = count + ' keywords';
});

document.getElementById('newResponse').addEventListener('input', function() {
    document.getElementById('responseCounter').textContent = this.value.length + ' caracteres';
    updatePreview();
});

// ============ AGREGAR LOTE DESDE JSON ============
function addBatchFromJSON() {
    var jsonText = prompt('📋 Pega aquí el JSON con las entradas (formato [{...},{...}]):');
    if (!jsonText || jsonText.trim() === '') return;
    
    try {
        var newEntries = JSON.parse(jsonText);
        if (!Array.isArray(newEntries)) {
            alert('❌ El JSON debe ser un array [...]');
            return;
        }
        
        var validEntries = [];
        for (var i = 0; i < newEntries.length; i++) {
            var e = newEntries[i];
            if (e.keywords && e.response) {
                validEntries.push({
                    keywords: Array.isArray(e.keywords) ? e.keywords : e.keywords.split(',').map(function(k){return k.trim().toLowerCase();}),
                    response: e.response,
                    model: e.model || 'eva',
                    created: new Date().toISOString()
                });
            }
        }
        
        if (validEntries.length === 0) {
            alert('❌ No se encontraron entradas válidas.');
            return;
        }
        
        var entries = getEntries();
        entries = entries.concat(validEntries);
        saveEntries(entries);
        alert('✅ ' + validEntries.length + ' entradas agregadas correctamente.');
    } catch(ex) {
        alert('❌ Error al leer el JSON. Revisa el formato.\n\n' + ex.message);
    }
}

// ============ AGREGAR ENTRADA ============
function addEntry() {
    var keywordsRaw = document.getElementById('newKeywords').value.trim();
    var responseText = document.getElementById('newResponse').value.trim();
    var model = document.getElementById('modelSelect').value;
    
    if (!keywordsRaw) { alert('Escribe al menos una keyword.'); return; }
    if (!responseText) { alert('Escribe la respuesta.'); return; }
    
    var keywords = keywordsRaw.split(',').map(function(k) { return k.trim().toLowerCase(); }).filter(Boolean);
    var entries = getEntries();
    
    entries.push({
        keywords: keywords,
        response: responseText,
        model: model,
        created: new Date().toISOString()
    });
    
    saveEntries(entries);
    document.getElementById('newKeywords').value = '';
    document.getElementById('newResponse').value = '';
    document.getElementById('keywordsCounter').textContent = '0 keywords';
    document.getElementById('responseCounter').textContent = '0 caracteres';
}

// ============ ELIMINAR ENTRADA ============
function deleteEntry(index) {
    if (!confirm('¿Eliminar esta entrada?')) return;
    var entries = getEntries();
    entries.splice(index, 1);
    saveEntries(entries);
}

// ============ EDITAR ENTRADA ============
function editEntry(index) {
    var entries = getEntries();
    var entry = entries[index];
    document.getElementById('newKeywords').value = entry.keywords.join(', ');
    document.getElementById('newResponse').value = entry.response;
    document.getElementById('modelSelect').value = entry.model;
    document.getElementById('keywordsCounter').textContent = entry.keywords.length + ' keywords';
    document.getElementById('responseCounter').textContent = entry.response.length + ' caracteres';
    entries.splice(index, 1);
    saveEntries(entries);
    window.scrollTo({ top: 0, behavior: 'smooth' });
}

// ============ RENDERIZAR LISTA ============
function renderEntries() {
    var entries = getEntries();
    var list = document.getElementById('entriesList');
    
    if (entries.length === 0) {
        list.innerHTML = '<div class="empty">📭 No hay entradas. Agrega tu primera pregunta y respuesta arriba.</div>';
        return;
    }
    
    list.innerHTML = entries.map(function(entry, index) {
        var badgeClass = 'badge-' + entry.model;
        var keywordsPreview = entry.keywords.join(', ');
        var responsePreview = entry.response.length > 150 ? entry.response.slice(0, 150) + '...' : entry.response;
        
        return '<div class="list-item">'
            + '<div class="list-header">'
            + '<span class="model-badge ' + badgeClass + '">' + entry.model.toUpperCase() + '</span>'
            + '<span style="font-size:11px;color:#999;">#' + (index + 1) + '</span>'
            + '<div>'
            + '<button class="btn btn-outline btn-sm" onclick="editEntry(' + index + ')" style="margin-right:4px;">✏️ Editar</button>'
            + '<button class="btn btn-danger btn-sm" onclick="deleteEntry(' + index + ')">🗑</button>'
            + '</div>'
            + '</div>'
            + '<strong style="font-size:12px;color:#888;">Keywords:</strong>'
            + '<div style="font-size:13px;margin-bottom:6px;word-break:break-all;">' + escHtml(keywordsPreview) + '</div>'
            + '<strong style="font-size:12px;color:#888;">Respuesta:</strong>'
            + '<div class="preview">' + escHtml(responsePreview) + '</div>'
            + '</div>';
    }).join('');
}

// ============ EXPORTAR / IMPORTAR / RESET ============
function exportData() {
    var entries = getEntries();
    if (entries.length === 0) { alert('No hay entradas para exportar.'); return; }
    var blob = new Blob([JSON.stringify(entries, null, 2)], { type: 'application/json' });
    var url = URL.createObjectURL(blob);
    var a = document.createElement('a');
    a.href = url;
    a.download = 'eva_entradas_' + new Date().toISOString().slice(0,10) + '.json';
    a.click();
    URL.revokeObjectURL(url);
}

function importData() {
    document.getElementById('importFile').click();
}

function handleImport(event) {
    var file = event.target.files[0];
    if (!file) return;
    var reader = new FileReader();
    reader.onload = function(e) {
        try {
            var data = JSON.parse(e.target.result);
            if (Array.isArray(data)) {
                if (confirm('Se importarán ' + data.length + ' entradas. ¿Sobrescribir las actuales?')) {
                    saveEntries(data);
                    alert('Importado correctamente.');
                }
            } else {
                alert('Formato inválido. Debe ser un array de entradas.');
            }
        } catch(ex) { alert('Error al leer el archivo JSON.'); }
    };
    reader.readAsText(file);
    event.target.value = '';
}

function resetAll() {
    if (confirm('⚠️ ¿Borrar TODAS las entradas personalizadas? Esto no se deshace.')) {
        localStorage.removeItem('eva_entries');
        renderEntries();
    }
}

// ============ ELIMINAR EN LOTE POR KEYWORD ============
function deleteByKeyword() {
    var keyword = prompt('🗑 Eliminar todas las entradas que contengan esta palabra (ej: trabajo, amigo, ex):');
    if (!keyword || keyword.trim() === '') return;
    
    keyword = keyword.trim().toLowerCase();
    var entries = getEntries();
    var toDelete = [];
    var toKeep = [];
    
    entries.forEach(function(entry) {
        var keywordsStr = entry.keywords.join(', ').toLowerCase();
        if (keywordsStr.includes(keyword)) {
            toDelete.push(entry);
        } else {
            toKeep.push(entry);
        }
    });
    
    if (toDelete.length === 0) {
        alert('✅ No hay entradas con la palabra: "' + keyword + '"');
        return;
    }
    
    if (confirm('⚠️ Se eliminarán ' + toDelete.length + ' entradas que contienen "' + keyword + '". ¿Continuar?')) {
        saveEntries(toKeep);
        alert('✅ Eliminadas ' + toDelete.length + ' entradas con "' + keyword + '".');
    }
}

// ============ BUSCADOR DE ENTRADAS ============
function searchEntries() {
    var searchTerm = prompt('🔍 Buscar keyword (ej: trabajo, amigo, ex):');
    if (!searchTerm || searchTerm.trim() === '') return;
    
    searchTerm = searchTerm.trim().toLowerCase();
    var entries = getEntries();
    var found = [];
    
    entries.forEach(function(entry, index) {
        var keywordsStr = entry.keywords.join(', ');
        if (keywordsStr.includes(searchTerm)) {
            found.push({ index: index, keywords: keywordsStr, response: entry.response.slice(0, 50) });
        }
    });
    
    if (found.length === 0) {
        alert('✅ No se encontraron entradas con: "' + searchTerm + '"');
        return;
    }
    
    var message = '🔍 ' + found.length + ' entradas con "' + searchTerm + '":\n\n';
    found.forEach(function(f) {
        message += '#' + (f.index + 1) + ': [' + f.keywords + ']\n📝 ' + f.response + '...\n\n';
    });
    message += '📋 Copia los números y bórralos manualmente.';
    
    alert(message);
}

// ============ UTILIDADES ============
function escHtml(str) {
    var div = document.createElement('div');
    div.textContent = str;
    return div.innerHTML;
}

// ============ INIT ============
renderEntries();

// ============ RESALTADO DE CÓDIGO ============
function updatePreview() {
    var text = document.getElementById('newResponse').value;
    var preview = document.getElementById('codePreview');
    
    if (text.trim().startsWith('<') || text.includes('function') || text.includes('```') || text.includes('const ') || text.includes('let ') || text.includes('var ')) {
        preview.style.display = 'block';
        preview.innerHTML = highlightCode(text);
    } else {
        preview.style.display = 'none';
    }
}

function formatCode() {
    var textarea = document.getElementById('newResponse');
    var text = textarea.value.trim();
    
    // Auto-detectar y formatear
    if (text.includes('```')) {
        // Ya tiene formato, no hacer nada
        alert('✅ El código ya tiene bloques de código.');
        return;
    }
    
    if (text.includes('<html') || text.includes('<!DOCTYPE')) {
        textarea.value = '```html\n' + text + '\n```';
    } else if (text.includes('function') || text.includes('const ') || text.includes('let ') || text.includes('var ')) {
        textarea.value = '```javascript\n' + text + '\n```';
    } else if (text.includes('{') && text.includes(':')) {
        textarea.value = '```css\n' + text + '\n```';
    } else if (text.includes('def ') || text.includes('import ') || text.includes('print(')) {
        textarea.value = '```python\n' + text + '\n```';
    }
    
    updatePreview();
    document.getElementById('responseCounter').textContent = textarea.value.length + ' caracteres';
}

function highlightCode(text) {
    var lines = text.split('\n');
    var result = '';
    
    lines.forEach(function(line, i) {
        var num = (i + 1).toString();
        var lineNum = '<span style="color:#555;margin-right:15px;user-select:none;">' + num + '</span>';
        
        // Colorear keywords
        var colored = line
            .replace(/(&lt;\/?[a-z]+[0-9]?)/gi, '<span style="color:#e94560;">$1</span>')
            .replace(/(function|const|let|var|return|if|else|for|while|class|import|export|from|async|await)/g, '<span style="color:#c792ea;">$1</span>')
            .replace(/(".*?"|'.*?'|`.*?`)/g, '<span style="color:#c3e88d;">$1</span>')
            .replace(/(\d+)/g, '<span style="color:#f78c6c;">$1</span>')
            .replace(/(\/\/.*)/g, '<span style="color:#546e7a;">$1</span>')
            .replace(/\/\*[\s\S]*?\*\//g, '<span style="color:#546e7a;">$&</span>');
        
        result += '<div>' + lineNum + colored + '</div>';
    });
    
    return result;
}

</script>

</body>
</html>
